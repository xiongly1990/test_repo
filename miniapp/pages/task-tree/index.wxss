.page {
  min-height: 100vh;
  background: #f7f8fc;
  padding-bottom: 140rpx;
}

.hero-section {
  position: relative;
  padding: 70rpx 40rpx 120rpx;
  background: linear-gradient(135deg, #81C784 0%, #4FC3F7 50%, #7986CB 100%);
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.bubble-1 {
  width: 180rpx;
  height: 180rpx;
  top: -60rpx;
  right: 40rpx;
}

.bubble-2 {
  width: 100rpx;
  height: 100rpx;
  bottom: 40rpx;
  left: 20rpx;
  background: rgba(255, 255, 255, 0.08);
}

.star {
  position: absolute;
  font-size: 36rpx;
  opacity: 0.4;
}

.star-1 {
  top: 40rpx;
  right: 200rpx;
  font-size: 32rpx;
}

.star-2 {
  top: 100rpx;
  right: 60rpx;
  font-size: 28rpx;
}

.star-3 {
  bottom: 60rpx;
  left: 180rpx;
  font-size: 24rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-title-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 36rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
}

.progress-stats-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.stat-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.streak-big {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
}

.streak-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.stat-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stat-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 8rpx;
}

.stat-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.content-wrap {
  margin-top: -60rpx;
  padding: 0 30rpx;
  position: relative;
  z-index: 10;
}

.tree-section {
  background: #fff;
  border-radius: 28rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(100, 150, 200, 0.1);
}

.section-header-row {
  display: flex;
  align-items: center;
}

.title-bar {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(to bottom, #81C784, #4FC3F7);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a2e;
  flex: 1;
}

.section-hint {
  display: block;
  font-size: 24rpx;
  color: #b0b0c0;
  margin-top: 12rpx;
  margin-left: 24rpx;
  margin-bottom: 24rpx;
}

.tree-container {
  position: relative;
  padding-left: 20rpx;
}

.tree-line {
  position: absolute;
  left: 68rpx;
  top: 20rpx;
  bottom: 20rpx;
  width: 4rpx;
  background: linear-gradient(to bottom, #81C784, #7986CB);
  border-radius: 2rpx;
}

.achievement-card {
  display: flex;
  align-items: flex-start;
  position: relative;
  margin-bottom: 28rpx;
  padding-left: 80rpx;
}

.achievement-card:last-child {
  margin-bottom: 0;
}

.card-dot {
  position: absolute;
  left: 58rpx;
  top: 24rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #81C784;
  z-index: 2;
}

.achievement-card.unlocked .card-dot {
  background: #81C784;
  border-color: #81C784;
}

.card-icon-wrap {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.card-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: #f5f5fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.card-icon.icon-glow {
  background: linear-gradient(135deg, #E8F5E9 0%, #B2DFDB 100%);
  box-shadow: 0 4rpx 16rpx rgba(129, 199, 132, 0.3);
}

.level-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  background: linear-gradient(135deg, #FF8A65 0%, #FF6B9D 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.card-content {
  flex: 1;
  padding-top: 6rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
}

.achievement-card.locked .card-name {
  color: #999;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

.progress-area {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f5;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(to right, #81C784, #4FC3F7);
  border-radius: 6rpx;
}

.progress-num {
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
}

.reward-tag {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  margin-top: 14rpx;
}

.reward-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.reward-tag text:last-child {
  font-size: 22rpx;
  color: #FF8F00;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(100, 150, 200, 0.1);
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}