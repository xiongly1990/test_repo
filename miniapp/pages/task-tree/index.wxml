<view class="page">
  <view class="hero-section">
    <view class="hero-bg">
      <view class="bubble bubble-1"></view>
      <view class="bubble bubble-2"></view>
      <view class="star star-1">✨</view>
      <view class="star star-2">🌟</view>
      <view class="star star-3">⭐</view>
    </view>
    
    <view class="hero-content">
      <view class="hero-title-row">
        <text class="hero-title">任务树</text>
        <text class="hero-subtitle">坚持打卡，解锁更多成就 🌳</text>
      </view>
      
      <view class="progress-stats-card">
        <view class="stat-main">
          <text class="streak-big">🔥 {{streakDays}}</text>
          <text class="streak-label">天连续打卡</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-side">
          <view class="stat-row">
            <text class="stat-num">{{unlockedCount}}</text>
            <text class="stat-text">已解锁</text>
          </view>
          <view class="stat-row">
            <text class="stat-num">{{totalAchievements}}</text>
            <text class="stat-text">总成就</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="content-wrap">
    <view class="tree-section">
      <view class="section-header-row">
        <view class="title-bar"></view>
        <text class="section-title">成就树</text>
      </view>
      <text class="section-hint">连续打卡天数越多，解锁的成就越多哦~</text>
      
      <view class="tree-container">
        <view class="tree-line"></view>
        <view
          class="achievement-card {{item.unlocked ? 'unlocked' : 'locked'}}"
          wx:for="{{tree}}"
          wx:key="id">
          <view class="card-dot"></view>
          <view class="card-icon-wrap">
            <view class="card-icon {{item.unlocked ? 'icon-glow' : ''}}">
              <text>{{item.unlocked ? item.icon : '🔒'}}</text>
            </view>
            <view class="level-badge" wx:if="{{item.unlocked}}">Lv.{{item.level}}</view>
          </view>
          <view class="card-content">
            <text class="card-name">{{item.name}}</text>
            <text class="card-desc">{{item.description}}</text>
            
            <view class="progress-area" wx:if="{{!item.unlocked}}">
              <view class="progress-bar">
                <view class="progress-fill" style="width: {{item.targetValue > 0 && streakDays < item.targetValue ? (streakDays / item.targetValue * 100) : 0}}%"></view>
              </view>
              <text class="progress-num">{{streakDays}}/{{item.targetValue}}天</text>
            </view>
            
            <view class="reward-tag" wx:if="{{item.unlocked}}">
              <text class="reward-icon">💎</text>
              <text>+{{item.points}}积分</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{tree.length === 0}}">
      <text class="empty-emoji">🌱</text>
      <text class="empty-title">暂无成就</text>
      <text class="empty-desc">快去打卡获取第一个成就吧~</text>
    </view>
  </view>
</view>