.page {
  min-height: 100vh;
  background: #f7f8fc;
  padding-bottom: 140rpx;
}

.hero-section {
  position: relative;
  padding: 70rpx 40rpx 120rpx;
  background: linear-gradient(135deg, #26C6DA 0%, #42A5F5 50%, #5C6BC0 100%);
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.bubble-1 {
  width: 180rpx;
  height: 180rpx;
  top: -60rpx;
  right: 30rpx;
}

.bubble-2 {
  width: 110rpx;
  height: 110rpx;
  bottom: 30rpx;
  left: 20rpx;
  background: rgba(255, 255, 255, 0.08);
}

.star {
  position: absolute;
  font-size: 36rpx;
  opacity: 0.4;
}

.star-1 {
  top: 30rpx;
  right: 180rpx;
  font-size: 32rpx;
}

.star-2 {
  top: 80rpx;
  right: 40rpx;
  font-size: 28rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-title-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 30rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
}

.mini-stats {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 24rpx 0;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
}

.mini-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
}

.mini-stat:last-child {
  border-right: none;
}

.mini-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.mini-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

.content-wrap {
  margin-top: -60rpx;
  padding: 0 30rpx;
  position: relative;
  z-index: 10;
}

.filter-tabs {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(50, 100, 150, 0.08);
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.filter-tab.active {
  background: linear-gradient(135deg, #26C6DA 0%, #42A5F5 100%);
  color: #fff;
  font-weight: 600;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(50, 100, 150, 0.06);
}

.record-date-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.record-day {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.record-month {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

.record-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-task {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.status-tag.pending {
  background: #FFF3E0;
  color: #FF8F00;
}

.status-tag.approved {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-tag.rejected {
  background: #FFEBEE;
  color: #F44336;
}

.record-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.record-time {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.time-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.record-points {
  font-size: 24rpx;
  color: #FF8F00;
  font-weight: 600;
}

.record-photo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.record-photo image {
  width: 100%;
  height: 100%;
}

.record-no-photo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: #E8F5E9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
  font-size: 40rpx;
  color: #4CAF50;
  font-weight: bold;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(50, 100, 150, 0.06);
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #42A5F5;
}