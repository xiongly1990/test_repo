.page {
  min-height: 100vh;
  background: #f7f8fc;
  padding-bottom: 140rpx;
}

.hero-section {
  position: relative;
  padding: 60rpx 40rpx 130rpx;
  background: linear-gradient(135deg, #FF8A65 0%, #FFB74D 50%, #FFD54F 100%);
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
}

.bubble-1 {
  width: 200rpx;
  height: 200rpx;
  top: -80rpx;
  right: -40rpx;
}

.bubble-2 {
  width: 120rpx;
  height: 120rpx;
  top: 100rpx;
  left: -30rpx;
  background: rgba(255, 255, 255, 0.12);
}

.bubble-3 {
  width: 80rpx;
  height: 80rpx;
  bottom: 40rpx;
  right: 100rpx;
  background: rgba(255, 255, 255, 0.1);
}

.star {
  position: absolute;
  font-size: 36rpx;
  opacity: 0.5;
}

.star-1 {
  top: 30rpx;
  left: 80rpx;
  font-size: 28rpx;
}

.star-2 {
  top: 50rpx;
  right: 200rpx;
  font-size: 32rpx;
}

.star-3 {
  bottom: 60rpx;
  left: 40rpx;
  font-size: 24rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 36rpx;
}

.date-text {
  display: flex;
  align-items: flex-end;
}

.date-big {
  font-size: 96rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.date-side {
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
  padding-bottom: 8rpx;
}

.month-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.weekday {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.streak-badge {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10px);
  padding: 14rpx 24rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.streak-flame {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.streak-num {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.hero-greeting {
  margin-bottom: 36rpx;
}

.greeting-text {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.greeting-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 10rpx;
}

.progress-bar-wrap {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.progress-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.progress-count {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.progress-track {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.content-wrap {
  margin-top: -70rpx;
  padding: 0 30rpx;
  position: relative;
  z-index: 10;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.section-count {
  font-size: 26rpx;
  color: #999;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(255, 138, 101, 0.08);
}

.task-card.completed {
  opacity: 0.6;
}

.task-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.task-icon {
  font-size: 48rpx;
}

.task-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.task-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.task-meta {
  display: flex;
  align-items: center;
}

.points-tag {
  display: flex;
  align-items: center;
  background: #FFF3E0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FF8F00;
  font-weight: 500;
}

.points-icon {
  font-size: 22rpx;
  margin-right: 4rpx;
}

.photo-tag {
  display: flex;
  align-items: center;
  background: #E3F2FD;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #1976D2;
  margin-left: 12rpx;
  font-weight: 500;
}

.photo-icon {
  font-size: 22rpx;
  margin-right: 4rpx;
}

.task-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.checkin-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  padding: 0 28rpx;
  background: linear-gradient(135deg, #FF8A65 0%, #FFB74D 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 34rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(255, 138, 101, 0.4);
}

.checkin-btn .btn-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.checkin-btn::after {
  border: none;
}

.done-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  padding: 0 24rpx;
  background: #E8F5E9;
  color: #4CAF50;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 34rpx;
}

.done-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 138, 101, 0.06);
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}