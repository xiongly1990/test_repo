.page {
  min-height: 100vh;
  background: #f7f8fc;
  padding-bottom: 140rpx;
}

.hero-section {
  position: relative;
  padding: 70rpx 40rpx 100rpx;
  background: linear-gradient(135deg, #FF8A65 0%, #FF6B9D 50%, #BA68C8 100%);
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.bubble-1 {
  width: 160rpx;
  height: 160rpx;
  top: -40rpx;
  right: 60rpx;
}

.bubble-2 {
  width: 100rpx;
  height: 100rpx;
  bottom: 20rpx;
  left: 30rpx;
  background: rgba(255, 255, 255, 0.08);
}

.bubble-3 {
  width: 60rpx;
  height: 60rpx;
  top: 40rpx;
  left: 40%;
  background: rgba(255, 255, 255, 0.1);
}

.star {
  position: absolute;
  font-size: 36rpx;
  opacity: 0.4;
}

.star-1 {
  top: 30rpx;
  right: 180rpx;
  font-size: 32rpx;
}

.star-2 {
  top: 80rpx;
  right: 40rpx;
  font-size: 28rpx;
}

.star-3 {
  bottom: 30rpx;
  left: 200rpx;
  font-size: 24rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.greeting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-block {
  display: flex;
  align-items: center;
}

.avatar-ring {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 24rpx;
}

.avatar-emoji {
  font-size: 56rpx;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 6rpx;
}

.streak-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border-radius: 40rpx;
  padding: 14rpx 24rpx 14rpx 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.streak-flame {
  font-size: 44rpx;
  margin-right: 8rpx;
}

.streak-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.streak-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.1;
}

.streak-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 2rpx;
}

.quote {
  margin-top: 36rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
}

.content-wrap {
  margin-top: -50rpx;
  padding: 0 30rpx;
  position: relative;
  z-index: 10;
}

.stats-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(120, 100, 200, 0.1);
}

.stat-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.stat-icon {
  font-size: 36rpx;
}

.points-bg {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.done-bg {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.days-bg {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.stat-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #f0f0f5;
}

.section-header {
  margin: 48rpx 10rpx 24rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
}

.title-bar {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(to bottom, #FF8A65, #FF6B9D);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a2e;
  flex: 1;
}

.section-date {
  font-size: 24rpx;
  color: #999;
}

.section-hint {
  display: block;
  font-size: 24rpx;
  color: #b0b0c0;
  margin-top: 12rpx;
  margin-left: 24rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(100, 100, 150, 0.06);
}

.task-card.task-done {
  opacity: 0.6;
}

.task-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.task-icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFEBF0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.task-icon-box.icon-done {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.task-icon {
  font-size: 48rpx;
}

.task-main {
  display: flex;
  flex-direction: column;
}

.task-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.task-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 16rpx;
}

.points-tag {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.points-diamond {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.points-num {
  font-size: 22rpx;
  color: #FF8F00;
  font-weight: 600;
}

.task-type-tag {
  font-size: 20rpx;
  color: #78909C;
  background: #ECEFF1;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

.task-action {
  flex-shrink: 0;
  margin-left: 20rpx;
}

.checkin-btn {
  background: linear-gradient(135deg, #FF8A65 0%, #FF6B9D 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 18rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 8rpx;
  line-height: 1.4;
  margin: 0;
  border: none;
}

.checkin-btn::after {
  border: none;
}

.btn-arrow {
  font-size: 28rpx;
  font-weight: bold;
  margin-left: 4rpx;
}

.done-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  color: #fff;
  padding: 14rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.done-check {
  font-size: 28rpx;
  font-weight: bold;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}