.page {
  min-height: 100vh;
  background: #f7f8fc;
  padding-bottom: 140rpx;
}

.hero-section {
  position: relative;
  padding: 80rpx 40rpx 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #9c27b0 100%);
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.bubble-1 {
  width: 200rpx;
  height: 200rpx;
  top: -70rpx;
  right: 20rpx;
}

.bubble-2 {
  width: 120rpx;
  height: 120rpx;
  bottom: 40rpx;
  left: 30rpx;
  background: rgba(255, 255, 255, 0.08);
}

.star {
  position: absolute;
  font-size: 36rpx;
  opacity: 0.4;
}

.star-1 {
  top: 30rpx;
  right: 180rpx;
  font-size: 32rpx;
}

.star-2 {
  top: 80rpx;
  right: 40rpx;
  font-size: 28rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.profile-top {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  margin-right: 28rpx;
}

.avatar-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-emoji {
  font-size: 72rpx;
}

.level-badge {
  position: absolute;
  bottom: 0;
  right: -8rpx;
  background: linear-gradient(135deg, #FF8A65 0%, #FF6B9D 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 3rpx solid #fff;
}

.profile-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.sub-info {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

.content-wrap {
  margin-top: -60rpx;
  padding: 0 30rpx;
  position: relative;
  z-index: 10;
}

.stats-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(100, 80, 200, 0.12);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
}

.stat-icon {
  font-size: 36rpx;
}

.streak-bg {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.days-bg {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.points-bg {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.stat-data {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 70rpx;
  background: #f0f0f5;
}

.menu-section {
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin: 0 10rpx 20rpx;
}

.title-bar {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(to bottom, #667eea, #764ba2);
  border-radius: 4rpx;
  margin-right: 14rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.menu-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(100, 80, 200, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 40rpx;
}

.record-bg {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.reward-bg {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.trophy-bg {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.about-bg {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a2e;
}

.menu-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.logout-section {
  margin-top: 40rpx;
  padding: 0 10rpx;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  color: #ff5252;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(255, 80, 80, 0.08);
}

.logout-btn::after {
  border: none;
}