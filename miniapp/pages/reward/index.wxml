<view class="page">
  <view class="hero-section">
    <view class="hero-bg">
      <view class="bubble bubble-1"></view>
      <view class="bubble bubble-2"></view>
      <view class="star star-1">✨</view>
      <view class="star star-2">⭐</view>
    </view>
    
    <view class="hero-content">
      <view class="hero-title-row">
        <text class="hero-title">奖励中心</text>
        <text class="hero-subtitle">用积分兑换喜欢的奖励 🎁</text>
      </view>
      
      <view class="points-card">
        <view class="points-left">
          <text class="points-label">我的积分</text>
          <view class="points-row">
            <text class="points-num">{{points}}</text>
            <text class="points-unit">积分</text>
          </view>
        </view>
        <view class="points-icon-box">
          <text class="points-icon">💎</text>
        </view>
      </view>
    </view>
  </view>

  <view class="content-wrap">
    <view class="category-scroll">
      <scroll-view scroll-x="{{true}}" class="cat-scroll">
        <view
          class="cat-item {{currentCategoryId === item.id ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onTabChange">
          <text class="cat-icon">{{item.iconEmoji}}</text>
          <text class="cat-name">{{item.name}}</text>
        </view>
      </scroll-view>
    </view>

    <view class="reward-grid">
      <view class="reward-card" wx:for="{{rewardList}}" wx:key="id" data-reward="{{item}}" bindtap="onRewardTap">
        <view class="reward-img-wrap">
          <text class="reward-emoji">{{item.iconEmoji}}</text>
          <view class="stock-badge" wx:if="{{item.stock > 0}}">
            <text>剩{{item.stock}}件</text>
          </view>
          <view class="sold-out" wx:elif="{{item.stock === 0}}">
            <text>已兑完</text>
          </view>
        </view>
        <view class="reward-info">
          <text class="reward-name">{{item.name}}</text>
          <text class="reward-desc">{{item.description}}</text>
          <view class="reward-bottom">
            <view class="price-tag">
              <text class="price-diamond">💎</text>
              <text class="price-num">{{item.points}}</text>
            </view>
            <button
              class="exchange-btn {{points >= item.points && item.stock > 0 ? '' : 'disabled'}}"
              disabled="{{points < item.points || item.stock === 0}}"
              catchtap="onExchange"
              data-reward="{{item}}">
              {{item.stock === 0 ? '已兑完' : (points >= item.points ? '立即兑换' : '积分不足')}}
            </button>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{rewardList.length === 0}}">
      <text class="empty-emoji">🎁</text>
      <text class="empty-title">暂无奖励</text>
      <text class="empty-desc">快去完成任务赚取积分吧~</text>
    </view>

    <view class="records-entry" bindtap="goToRecords">
      <view class="entry-left">
        <text class="entry-icon">📋</text>
        <view class="entry-text">
          <text class="entry-title">兑换记录</text>
          <text class="entry-sub">查看历史兑换记录</text>
        </view>
      </view>
      <text class="entry-arrow">›</text>
    </view>
  </view>
</view>