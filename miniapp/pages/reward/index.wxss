.page {
  min-height: 100vh;
  background: #f7f8fc;
  padding-bottom: 140rpx;
}

.hero-section {
  position: relative;
  padding: 70rpx 40rpx 130rpx;
  background: linear-gradient(135deg, #FF9800 0%, #FF5722 50%, #E91E63 100%);
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.bubble-1 {
  width: 180rpx;
  height: 180rpx;
  top: -50rpx;
  right: 30rpx;
}

.bubble-2 {
  width: 120rpx;
  height: 120rpx;
  bottom: 30rpx;
  left: 40rpx;
  background: rgba(255, 255, 255, 0.08);
}

.star {
  position: absolute;
  font-size: 36rpx;
  opacity: 0.4;
}

.star-1 {
  top: 40rpx;
  right: 200rpx;
  font-size: 32rpx;
}

.star-2 {
  top: 90rpx;
  right: 50rpx;
  font-size: 28rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-title-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 30rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
}

.points-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.points-left {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.points-row {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.points-num {
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.points-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 8rpx;
}

.points-icon-box {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.points-icon {
  font-size: 56rpx;
}

.content-wrap {
  margin-top: -70rpx;
  padding: 0 30rpx;
  position: relative;
  z-index: 10;
}

.category-scroll {
  margin-bottom: 24rpx;
}

.cat-scroll {
  white-space: nowrap;
}

.cat-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 100, 50, 0.08);
}

.cat-item.active {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.cat-icon {
  font-size: 48rpx;
}

.cat-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

.cat-item.active .cat-name {
  color: #FF6F00;
  font-weight: 600;
}

.reward-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 8rpx;
}

.reward-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 100, 50, 0.08);
}

.reward-img-wrap {
  position: relative;
  height: 200rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.reward-emoji {
  font-size: 80rpx;
}

.stock-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #FF6F00;
}

.sold-out {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.sold-out text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.reward-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.reward-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.reward-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.reward-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.price-tag {
  display: flex;
  align-items: center;
}

.price-diamond {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.price-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6F00;
}

.exchange-btn {
  background: linear-gradient(135deg, #FF9800 0%, #FF5722 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 12rpx 24rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
  margin: 0;
  border: none;
}

.exchange-btn::after {
  border: none;
}

.exchange-btn.disabled {
  background: #e0e0e0;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 100, 50, 0.08);
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.records-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 100, 50, 0.08);
}

.entry-left {
  display: flex;
  align-items: center;
}

.entry-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.entry-text {
  display: flex;
  flex-direction: column;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.entry-sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.entry-arrow {
  font-size: 40rpx;
  color: #ccc;
}