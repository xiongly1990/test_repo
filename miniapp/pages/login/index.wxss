.page {
  min-height: 100vh;
  background: #f7f8fc;
}

.hero-section {
  position: relative;
  padding: 100rpx 40rpx 140rpx;
  background: linear-gradient(135deg, #FF9A9E 0%, #FECFEF 50%, #A18CD1 100%);
  border-radius: 0 0 56rpx 56rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.bubble-1 {
  width: 240rpx;
  height: 240rpx;
  top: -100rpx;
  right: -60rpx;
}

.bubble-2 {
  width: 140rpx;
  height: 140rpx;
  top: 140rpx;
  left: -40rpx;
  background: rgba(255, 255, 255, 0.15);
}

.bubble-3 {
  width: 90rpx;
  height: 90rpx;
  bottom: 60rpx;
  right: 120rpx;
  background: rgba(255, 255, 255, 0.12);
}

.star {
  position: absolute;
  font-size: 40rpx;
  opacity: 0.5;
}

.star-1 {
  top: 40rpx;
  left: 60rpx;
  font-size: 32rpx;
}

.star-2 {
  top: 80rpx;
  right: 200rpx;
  font-size: 36rpx;
}

.star-3 {
  bottom: 80rpx;
  left: 50rpx;
  font-size: 28rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-wrap {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(10px);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.4);
}

.logo-emoji {
  font-size: 72rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 16rpx;
}

.content-wrap {
  margin-top: -60rpx;
  padding: 0 30rpx 60rpx;
  position: relative;
  z-index: 10;
}

.login-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(161, 140, 209, 0.12);
}

.section-header {
  text-align: center;
  margin-bottom: 36rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.section-hint {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.children-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 36rpx;
}

.child-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
}

.child-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  transition: all 0.3s;
  border: 4rpx solid transparent;
}

.child-item.selected .child-avatar {
  border-color: #FF9A9E;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFEFEF 100%);
  transform: scale(1.05);
}

.child-emoji {
  font-size: 64rpx;
}

.select-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #FF9A9E 0%, #A18CD1 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  border: 3rpx solid #fff;
}

.child-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.empty-children {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #FF9A9E 0%, #A18CD1 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 158, 0.4);
}

.login-btn.disabled {
  background: linear-gradient(135deg, #ddd 0%, #ccc 100%);
  box-shadow: none;
}

.login-btn .btn-arrow {
  margin-left: 10rpx;
  font-size: 32rpx;
}

.login-btn::after {
  border: none;
}

.register-card {
  margin-top: 30rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(161, 140, 209, 0.08);
}

.register-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #eee;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #999;
}

.register-form {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.input-group {
  display: flex;
  align-items: center;
  background: #f7f8fc;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  height: 44rpx;
}

.avatar-picker {
  margin-bottom: 24rpx;
}

.picker-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.avatar-scroll {
  white-space: nowrap;
}

.avatar-option {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  background: #f7f8fc;
  border-radius: 50%;
  margin-right: 16rpx;
  font-size: 48rpx;
  transition: all 0.3s;
  border: 4rpx solid transparent;
}

.avatar-option.selected {
  border-color: #FF9A9E;
  background: #FFF5F5;
  transform: scale(1.1);
}

.register-actions {
  display: flex;
  gap: 20rpx;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #FF9A9E 0%, #A18CD1 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
}

.confirm-btn::after {
  border: none;
}

.cancel-btn {
  flex: 1;
  height: 80rpx;
  background: #f0f0f0;
  color: #666;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
}

.cancel-btn::after {
  border: none;
}

.register-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #fff;
  color: #A18CD1;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: 3rpx solid #A18CD1;
}

.register-btn .register-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.register-btn::after {
  border: none;
}