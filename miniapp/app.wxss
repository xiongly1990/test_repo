page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.container {
  padding: 30rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 28rpx;
  line-height: 1;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: #ccc;
  color: #fff;
}

.tag-success {
  background: #e8f8e8;
  color: #67c23a;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-warning {
  background: #fff3e8;
  color: #e6a23c;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-info {
  background: #f5f7fa;
  color: #909399;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
